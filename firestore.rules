rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/players/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "kingoflakemoor@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidPlayer(data) {
      return data.uid is string && data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidTournament(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.status in ['upcoming', 'live', 'completed'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /players/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(uid) && isValidPlayer(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(uid) || isAdmin()) && isValidPlayer(request.resource.data);
    }

    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidTournament(request.resource.data);
      allow delete: if isAdmin();

      match /matches/{matchId} {
        allow read: if isAuthenticated();
        allow create, update: if isAdmin();
      }
    }

    match /venues/{venueId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /seasons/{seasonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
